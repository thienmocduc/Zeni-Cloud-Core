# ZeniCloud Router - copy this to .env and fill in real values
# NEVER commit .env to git

# ─── Service ───
APP_NAME=zenicloud-router
APP_VERSION=0.1.0
ENV=dev
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080

# ─── Security (CRITICAL: rotate before prod) ───
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_IN_PROD_USE_64CHAR_RANDOM_STRING_FROM_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
RATE_LIMIT_PER_MINUTE=100
MAX_REQUEST_SIZE_MB=10

# Allowlist
# ALLOWED_ORIGINS=https://zenicloud.io,https://zenidigital.com,https://zeni.holdings,http://localhost:3000

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://zeni:zeni@localhost:5432/zenicloud_router
DB_POOL_SIZE=20

# ─── Cache ───
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300
SEMANTIC_CACHE_ENABLED=true

# ─── Provider keys (LEAVE BLANK if USE_MOCK_ADAPTERS=true) ───
USE_MOCK_ADAPTERS=true

# Anthropic — get from console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — get from platform.openai.com (or via Bedrock)
# OPENAI_API_KEY=sk-...

# Google — get from console.cloud.google.com (Vertex AI)
# GOOGLE_API_KEY=...
# GCP_PROJECT_ID=zeni-cloud-prod
# GCP_LOCATION=asia-southeast1

# AWS Bedrock — IAM user with bedrock:InvokeModel
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=ap-southeast-1

# ─── Routing strategy ───
DEFAULT_TIER=balanced
QUALITY_THRESHOLD_FAST=0.65
QUALITY_THRESHOLD_BALANCED=0.85
COST_BUDGET_USD_PER_REQUEST=0.50
ENABLE_FAILOVER=true
FAILOVER_TIMEOUT_SECONDS=8

# ─── Telemetry ───
PROMETHEUS_ENABLED=true
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317

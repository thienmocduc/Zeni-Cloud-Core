# ═══ ZENI CLOUD CORE · ENV SAMPLE ═══
# Copy → .env and fill real values before running.

# ─── Database ───────────────────────────────────────
POSTGRES_USER=zeni
POSTGRES_PASSWORD=change_me_strong_password_here
POSTGRES_DB=zeni_cloud
DATABASE_URL=postgresql+asyncpg://zeni:change_me_strong_password_here@postgres:5432/zeni_cloud

# ─── Redis ──────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT / Session ──────────────────────────────────
JWT_SECRET=generate_with_openssl_rand_hex_32
JWT_ALG=HS256
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000

# ─── Vault (secrets encryption) ─────────────────────
# Fernet 32-byte key, generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_KEY=generate_with_cryptography_fernet_generate_key

# ─── LLM Providers ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=  # leave blank if using Vertex AI (recommended — uses service account)

# ─── Google Cloud (preferred path for Gemini via Vertex AI) ──
GCP_PROJECT_ID=zeni-cloud-core
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-sa-key.json  # mounted into backend container
GCS_BUCKET_PREFIX=zeni-

# ─── CORS / Host ────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000
APP_BASE_URL=http://localhost:8080

# ─── Admin seed (first boot) ────────────────────────
ADMIN_EMAIL=ceo@zeni-holdings.vn
ADMIN_PASSWORD=ChangeMeImmediately123!
ADMIN_NAME=CEO Zeni

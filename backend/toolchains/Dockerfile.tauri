FROM rust:1.80-bookworm
RUN apt-get update && apt-get install -y --no-install-recommends \
    libwebkit2gtk-4.0-dev libssl-dev libgtk-3-dev libayatana-appindicator3-dev \
    librsvg2-dev curl build-essential && rm -rf /var/lib/apt/lists/*
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && rm -rf /var/lib/apt/lists/*
RUN npm install -g @tauri-apps/cli@2 && cargo install create-tauri-app --locked
WORKDIR /workspace
CMD ["bash"]

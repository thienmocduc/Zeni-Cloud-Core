# =========================================================================
# ZeniAccessControl — environment variables
# Copy to .env and fill in. NEVER commit .env to git.
# =========================================================================

# -- Deployer wallet private key (NO 0x prefix or with prefix both ok) -----
DEPLOYER_PRIVATE_KEY=

# -- RPC endpoints --------------------------------------------------------
# Polygon mainnet (default: https://polygon-rpc.com). Use Alchemy/Infura URL
# in production for higher rate limits.
POLYGON_RPC_URL=https://polygon-rpc.com

# Polygon Mumbai testnet
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# -- Polygonscan API key (for contract verification) ----------------------
POLYGONSCAN_API_KEY=

# -- Initialization parameters --------------------------------------------
# Address that becomes chairman on initialize(). If left blank the deploy
# script falls back to the deployer address.
CHAIRMAN_ADDRESS=

# Comma-separated list of admin wallets to whitelist after deploy.
# Example: 0xAaa...,0xBbb...
INITIAL_ADMINS=

# Comma-separated list of EXACTLY 5 legal signer wallets.
# Example: 0xLegal1...,0xLegal2...,0xLegal3...,0xLegal4...,0xLegal5...
INITIAL_LEGAL_SIGNERS=

# -- Optional ------------------------------------------------------------
# Set to "true" to print gas usage during tests.
REPORT_GAS=false
